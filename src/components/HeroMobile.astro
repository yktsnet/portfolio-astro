---
interface Props {
  current?: string;
}
const { current } = Astro.props;

const navItems = [
  { label: 'ABOUT', href: '/', key: 'about' },
  { label: 'APPROACH', href: '/approach/', key: 'approach' },
  { label: 'IMPACT', href: '/impact/', key: 'impact' },
  { label: 'WORKS', href: '/works/', key: 'works' },
];
---

<div class="flex flex-col items-center gap-5">
  <img
    src="/images/profile/me.webp"
    alt="Katsuhiro Yamakawa"
    class="h-28 w-28 rounded-full object-cover shrink-0"
  />
  <div class="text-center">
    <h1 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-poi-focus">
      Katsuhiro Yamakawa
    </h1>
    <p class="text-sm text-poi-accent mt-0.5">
      Builder
    </p>
    <nav class="mt-5 flex flex-nowrap items-center justify-center gap-2 text-sm" aria-label="ページナビゲーション">
      {navItems.map((item) => (
        <a
          href={item.href}
          aria-current={current === item.key ? 'page' : false}
          class:list={[
            "whitespace-nowrap rounded-full border px-3 py-1 transition-colors",
            current === item.key
              ? "border-poi-accent/50 bg-poi-accent/5 text-poi-accent"
              : "border-zinc-300 dark:border-poi-border text-zinc-600 dark:text-poi-muted hover:text-poi-accent hover:border-poi-accent/40",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</div>
