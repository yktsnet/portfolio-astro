---
import Search from './Search.astro';
import ThemeToggle from './ThemeToggle.astro';
import RightNav from './RightNav.astro';
import Logo from '../layouts/Logo.astro';
import { menuLinks } from '../site.config';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const isHome = currentPath === "/";
const isPhotos = currentPath === "/photos/";
const navLinks = menuLinks.map((l) => ({
  ...l,
  isCurrent: currentPath === l.path,
}));
---
<header class="group relative mb-16 flex items-center sm:ps-[4.5rem]" id="main-header">
  <div class="relative flex sm:flex-col">
    <div class="group/logo hidden sm:block sm:absolute sm:-start-[4.5rem] sm:top-1/2 sm:-translate-y-1/2 sm:grayscale sm:hover:filter-none sm:transition-[filter]">
      <Logo class="site-logo-icon transition-transform duration-500 ease-out group-hover/logo:rotate-180" />
    </div>
    <a
      aria-current={isHome ? "page" : false}
      class="inline-flex items-center"
      href="/"
    >
      <div class="group/logo me-3 sm:hidden">
        <Logo class="site-logo-icon transition-transform duration-500 ease-out group-hover/logo:rotate-180" />
      </div>
      <span class="text-xl font-bold sm:text-2xl text-zinc-900 dark:text-poi-focus">ykts.net</span>
    </a>
    <nav
      aria-label="Main menu"
      class="bg-zinc-50 dark:bg-poi-base absolute -inset-x-4 top-14 hidden flex-col divide-y px-2 py-4 sm:static sm:z-auto sm:-ms-4 sm:mt-1 sm:flex sm:flex-row sm:divide-x sm:divide-y-0 sm:divide-light-accent dark:sm:divide-poi-accent sm:bg-transparent sm:p-0"
      id="navigation-menu"
    >
      {navLinks.map((link) => (
        <a
          aria-current={link.isCurrent ? "page" : false}
          class="text-light-accent dark:text-poi-accent px-2 py-4 font-semibold sm:px-4 sm:py-0 sm:underline-offset-2 sm:hover:underline"
          href={link.path}
        >
          {link.title}
        </a>
      ))}
    </nav>
  </div>
  <RightNav isPhotos={isPhotos} />
</header>

