---
import { getLucideIcon } from '../lib/lucide';

interface Props {
  current?: string;
}
const { current } = Astro.props;

const items = [
  { label: 'About', href: '/', key: 'about', icon: 'circle-user-round' },
  { label: 'Approach', href: '/approach/', key: 'approach', icon: 'brain' },
  { label: 'Impact', href: '/impact/', key: 'impact', icon: 'thumbs-up' },
  { label: 'Works', href: '/works/', key: 'works', icon: 'flag' },
];
---

<aside class="w-56 shrink-0 sticky top-12 self-start hidden sm:block">
  <img
    src="/images/profile/me.webp"
    alt="Katsuhiro Yamakawa"
    class="h-32 w-32 rounded-full object-cover"
  />
  <div class="mt-5">
    <h1 class="whitespace-nowrap text-xl font-semibold tracking-tight text-zinc-900 dark:text-poi-focus">
      Katsuhiro Yamakawa
    </h1>
    <p class="text-sm text-poi-accent mt-1">
      Builder
    </p>
    <p class="mt-3 text-xs leading-relaxed text-zinc-500 dark:text-poi-muted">
      Breaking down legacy systems and rebuilding them. IoT, infra automation, NixOS. Wiring AI agents into real work.
    </p>
  </div>
  <nav class="mt-6 flex flex-col items-start gap-3 text-base" aria-label="ページナビゲーション">
    {items.map((item) => (
      <a
        href={item.href}
        aria-current={current === item.key ? 'page' : false}
        class:list={[
          "group inline-flex items-center gap-2.5 transition-colors hover:text-poi-accent dark:hover:text-poi-accent",
          current === item.key ? "text-poi-accent" : "text-zinc-500 dark:text-poi-muted",
        ]}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16" height="16" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="1.5"
          stroke-linecap="round" stroke-linejoin="round"
          class:list={[
            "shrink-0 transition-colors",
            current === item.key ? "text-poi-accent" : "text-zinc-400 dark:text-zinc-600 group-hover:text-poi-accent",
          ]}
          aria-hidden="true"
          set:html={getLucideIcon(item.icon)}
        />
        {item.label}
      </a>
    ))}
  </nav>
</aside>
