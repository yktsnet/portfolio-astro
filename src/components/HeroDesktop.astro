---
interface Props {
  current?: string;
}
const { current } = Astro.props;

const items = [
  { label: 'About', href: '/', key: 'about' },
  { label: 'Approach', href: '/approach/', key: 'approach' },
  { label: 'Impact', href: '/impact/', key: 'impact' },
  { label: 'Works', href: '/works/', key: 'works' },
];
---

<aside class="w-56 shrink-0 sticky top-12 self-start hidden sm:block">
  <img
    src="/images/profile/me.webp"
    alt="Katsuhiro Yamakawa"
    class="h-32 w-32 rounded-full object-cover"
  />
  <div class="mt-5">
    <h1 class="whitespace-nowrap text-xl font-semibold tracking-tight text-zinc-900 dark:text-poi-focus">
      Katsuhiro Yamakawa
    </h1>
    <p class="text-sm text-poi-accent mt-1">
      Builder
    </p>
    <p class="mt-3 text-xs leading-relaxed text-zinc-500 dark:text-poi-muted">
      Breaking down legacy systems and rebuilding them. IoT, infra automation, NixOS. Wiring AI agents into real work.
    </p>
  </div>
  <nav class="mt-6 space-y-2.5 text-lg" aria-label="ページナビゲーション">
    {items.map((item) => (
      <a
        href={item.href}
        aria-current={current === item.key ? 'page' : false}
        class:list={[
          "block transition-colors hover:text-poi-accent dark:hover:text-poi-accent",
          current === item.key
            ? "text-poi-accent"
            : "text-zinc-500 dark:text-poi-muted",
        ]}
      >
        {item.label}
      </a>
    ))}
  </nav>
</aside>
