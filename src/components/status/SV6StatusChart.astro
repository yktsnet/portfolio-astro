---
// SV6（自宅サーバー・複数プロダクト同居ホスト）の稼働実態を示すライブメトリクス。
// HostingArchitecture.astro のトグルから開かれたタイミングで /api/sv6-status を
// 遅延フェッチし、単一のSVGチャート（ハートビート列 + Load%/Available%の折れ線）を描画する。
---

<div id="sv6-chart-root">
  <div
    id="sv6-chart-display"
    class="rounded-xl border border-zinc-200 dark:border-poi-border bg-white dark:bg-poi-panel px-4 py-5 sm:px-6"
  >
    <div class="h-[180px] flex items-center justify-center">
      <span class="font-mono text-xs text-zinc-400 dark:text-poi-muted/40">読み込み中…</span>
    </div>
  </div>

  <!-- 固定の解説3本（タブ切り替え不要・常時表示） -->
  <div id="sv6-chart-notes" class="mt-4 space-y-1.5"></div>

  <!-- 基礎スペック（静的1行） -->
  <p class="mt-4 font-mono text-[11px] text-zinc-400 dark:text-poi-muted/60">
    Intel Core i5-8365U (4C/8T) ・ 8コア ・ 8GB RAM
  </p>

  <!-- 補足（Swap・コンテナ数を1行に統合、常時表示） -->
  <p id="sv6-extra-line" class="mt-1 font-mono text-[11px] text-zinc-400 dark:text-poi-muted/60"></p>
</div>

<script>
  import type { SV6StatusPayload } from "../../lib/sv6-status";
  import {
    loadPercentSeries,
    availablePercentSeries,
    uptimeDays,
  } from "../../lib/sv6-status";
  import { formatUpdatedAt } from "../../lib/status";

  const NS = "http://www.w3.org/2000/svg";
  const isDark = () => document.documentElement.classList.contains("dark");

  const C = () =>
    isDark()
      ? {
          heartbeat: "#5de4c7",
          load: "#5de4c7",
          available: "#89ddff",
          grid: "#ffffff10",
          axis: "#ffffff55",
        }
      : {
          heartbeat: "#d0679d",
          load: "#d0679d",
          available: "#d0679d",
          grid: "#00000010",
          axis: "#00000066",
        };

  function el(tag: string, attrs: Record<string, string | number> = {}) {
    const e = document.createElementNS(NS, tag);
    for (const [k, v] of Object.entries(attrs)) e.setAttribute(k, String(v));
    return e;
  }
  function txt(content: string, attrs: Record<string, string | number> = {}) {
    const e = el("text", {
      fill: C().axis,
      "font-size": 11,
      "font-family": '"Fira Code", "IBM Plex Mono", monospace',
      ...attrs,
    });
    e.textContent = content;
    return e;
  }

  function buildChart(data: SV6StatusPayload): SVGElement {
    const W = 600, H = 240, PL = 44, PR = 12, PT = 56, PB = 38;
    const cW = W - PL - PR, cH = H - PT - PB;
    const svg = el("svg", { viewBox: `0 0 ${W} ${H}`, width: "100%" }) as unknown as SVGElement;

    const heartbeats = data.heartbeats ?? [];
    const n = heartbeats.length;
    const dotY = 18;

    if (n > 0) {
      heartbeats.forEach((_t, i) => {
        const x = n === 1 ? PL + cW / 2 : PL + (i / (n - 1)) * cW;
        svg.appendChild(el("circle", { cx: x, cy: dotY, r: 3, fill: C().heartbeat, opacity: 0.85 }));
      });
    } else {
      svg.appendChild(txt("no heartbeat data", { x: PL, y: dotY + 4 }));
    }
    svg.appendChild(txt("HEARTBEAT", { x: PL, y: dotY - 10, "font-size": 10, opacity: 0.7 }));

    // 0-100% 共有軸のグリッド
    [0, 0.5, 1].forEach((r) => {
      const y = PT + r * cH;
      svg.appendChild(el("line", { x1: PL, x2: PL + cW, y1: y, y2: y, stroke: C().grid }));
      svg.appendChild(txt(`${Math.round(100 * (1 - r))}%`, { x: PL - 6, y: y + 4, "text-anchor": "end" }));
    });

    const loadSeries = loadPercentSeries(data);
    const availSeries = availablePercentSeries(data);

    function pointsFor(series: number[]): string {
      const len = series.length;
      if (!len) return "";
      return series
        .map((v, i) => {
          const x = len === 1 ? PL + cW / 2 : PL + (i / (len - 1)) * cW;
          const y = PT + cH * (1 - v / 100);
          return `${x},${y}`;
        })
        .join(" ");
    }

    if (availSeries.length) {
      svg.appendChild(
        el("polyline", { points: pointsFor(availSeries), fill: "none", stroke: C().available, "stroke-width": 2 })
      );
    }
    if (loadSeries.length) {
      svg.appendChild(
        el("polyline", { points: pointsFor(loadSeries), fill: "none", stroke: C().load, "stroke-width": 2 })
      );
    }
    if (!loadSeries.length && !availSeries.length) {
      svg.appendChild(txt("no metrics data", { x: PL, y: PT + cH / 2 }));
    }

    return svg;
  }

  function renderNotes(data: SV6StatusPayload) {
    const notesEl = document.getElementById("sv6-chart-notes");
    if (!notesEl) return;

    const days = uptimeDays(data);
    const loadSeries = loadPercentSeries(data);
    const availSeries = availablePercentSeries(data);
    const maxLoad = loadSeries.length ? Math.max(...loadSeries) : 0;
    const minAvail = availSeries.length ? Math.min(...availSeries) : 0;
    const loadCeil = Math.max(5, Math.ceil(maxLoad / 5) * 5);
    const availFloor = Math.min(90, Math.floor(minAvail / 10) * 10);

    const notes = [
      { label: "稼働継続", text: `${days}日連続稼働` },
      { label: "低負荷", text: `CPU負荷は常時${loadCeil}%未満` },
      { label: "メモリの健全性", text: `キャッシュ込みでも常に${availFloor}%以上の余裕を維持` },
    ];

    notesEl.innerHTML = notes
      .map(
        (n) => `
        <div class="flex items-start gap-2 text-xs font-mono text-zinc-500 dark:text-poi-muted/70 leading-5">
          <span class="shrink-0 mt-0.5 text-light-accent dark:text-poi-accent">—</span>
          <span><span class="text-zinc-400 dark:text-poi-muted/50">${n.label}:</span> ${n.text}</span>
        </div>`
      )
      .join("");
  }

  function renderExtraLine(data: SV6StatusPayload) {
    const line = document.getElementById("sv6-extra-line");
    if (!line) return;
    const swap = (data.swap_used_percent ?? 0).toFixed(1);
    const containers = data.containers_running ?? "—";
    line.textContent = `Swap ${swap}% ・ コンテナ${containers}個稼働中`;
  }

  function renderUpdatedAt(data: SV6StatusPayload) {
    const notesEl = document.getElementById("sv6-chart-notes");
    if (!notesEl || !data.updated_at) return;
    const caption = document.createElement("p");
    caption.className = "font-mono text-[10px] text-zinc-400 dark:text-poi-muted/40 pt-1";
    caption.textContent = `最終更新: ${formatUpdatedAt(data.updated_at)}`;
    notesEl.appendChild(caption);
  }

  function render(data: SV6StatusPayload) {
    const display = document.getElementById("sv6-chart-display");
    if (display) {
      display.innerHTML = "";
      display.appendChild(buildChart(data));
    }
    renderNotes(data);
    renderUpdatedAt(data);
    renderExtraLine(data);
  }

  function renderFallback() {
    const display = document.getElementById("sv6-chart-display");
    if (display) {
      display.innerHTML = `
        <div class="h-[180px] flex flex-col items-center justify-center gap-2">
          <span class="font-mono text-xs text-zinc-400 dark:text-poi-muted/60">データを取得できませんでした</span>
        </div>`;
    }
    const notesEl = document.getElementById("sv6-chart-notes");
    if (notesEl) notesEl.innerHTML = "";
  }

  let loaded = false;
  let loading = false;

  async function loadAndRender() {
    if (loaded || loading) return;
    loading = true;
    try {
      const res = await fetch("/api/sv6-status");
      if (!res.ok) throw new Error(`api ${res.status}`);
      const data = (await res.json()) as SV6StatusPayload;
      render(data);
      loaded = true;
    } catch {
      renderFallback();
    } finally {
      loading = false;
    }
  }

  function init() {
    // HostingArchitecture.astro 側のトグルが初めて開かれたタイミングでフェッチする
    const panel = document.getElementById("sv6-status-panel");
    if (panel) {
      panel.addEventListener("sv6-status:open", loadAndRender, { once: true });
    }
  }

  document.addEventListener("DOMContentLoaded", init);
</script>
