---
import MainLayout from '../layouts/MainLayout.astro';
import { works } from '../data/works';
import { getLucideIcon } from '../lib/lucide';

const featuredWorks = works.filter(w => w.featured).map(work => ({
  ...work,
  iconPath: getLucideIcon(work.icon),
}));
---

<MainLayout title="Home">

  <!-- ===== Hero ===== -->
  <section class="mb-8">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center">
      <img
        src="/images/profile/me.webp"
        alt="Katsuhiro Yamakawa"
        class="h-20 w-20 shrink-0 rounded-full object-cover sm:h-24 sm:w-24"
      />
      <div class="min-w-0">
        <h1 class="text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl dark:text-poi-focus">
          Katsuhiro Yamakawa
        </h1>
      </div>
    </div>
  </section>

  <!-- ===== Description + Stack ===== -->
  <section class="mb-12 max-w-3xl">
    <p class="font-sans text-sm leading-7 text-zinc-600 dark:text-poi-muted">
      レガシーをバラして作り直すのが好き。IoT・インフラ自動化・NixOS。<br />
      AIエージェントを実務に組み込む実験を続けている。
    </p>
  </section>

  <!-- ===== Works ===== -->
  <section class="mb-12">
    <div class="flex items-baseline justify-between mb-1">
      <div class="flex items-baseline gap-3">
        <h2 class="font-mono text-xs font-semibold text-zinc-900 dark:text-poi-focus">Works</h2>
        <span class="font-mono text-xs text-zinc-400 dark:text-zinc-500">{featuredWorks.length} in production</span>
      </div>
      <a class="cactus-link font-mono text-xs" href="/works/">すべて見る →</a>
    </div>
    <div class="divide-y divide-zinc-100 dark:divide-poi-border/60">
      {featuredWorks.map((work) => (
        <div class="py-4 flex gap-4 items-start">
          <div
            class="mt-0.5 shrink-0 flex items-center justify-center w-8 h-8 rounded-lg"
            style={`background:${work.color}18`}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15" height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              style={`color:${work.color}`}
              set:html={work.iconPath}
            />
          </div>
          <div class="min-w-0 flex-1">
            <p class="font-mono text-xs" style={`color:${work.color}`}>{work.tag}</p>
            <h3 class="mt-0.5 font-semibold text-sm text-zinc-900 dark:text-poi-focus">{work.title}</h3>
            <p class="mt-1 font-sans text-xs leading-6 text-zinc-500 dark:text-poi-muted">
              {work.featuredDescription ?? work.description}
            </p>
            {work.stack && work.stack.length > 0 && (
              <div class="mt-1.5 flex flex-wrap gap-1">
                {work.stack.map((s) => (
                  <span class="inline-flex items-center rounded-full border border-zinc-200 dark:border-poi-border px-2 py-0.5 font-mono text-[10px] text-zinc-500 dark:text-zinc-400">
                    {s}
                  </span>
                ))}
              </div>
            )}
            <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 font-mono text-xs">
              {work.links.map((link) => (
                <a
                  class="hover:underline underline-offset-2 transition-opacity hover:opacity-80"
                  style={`color:${work.color}`}
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

</MainLayout>
