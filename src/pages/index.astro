---
import MainLayout from '../layouts/MainLayout.astro';
import SocialList from '../components/SocialList.astro';
import PostPreview from '../components/blog/PostPreview.astro';
import { getAllPosts } from '../data/post';
import { collectionDateSort } from '../utils/date';

const MAX_PINNED = 3;
const MAX_RECENT = 5;

const allPosts = await getAllPosts();
const sortedPosts = allPosts.sort(collectionDateSort);
const pinnedPosts = sortedPosts.filter((p) => p.data.pinned).slice(0, MAX_PINNED);
const recentPosts = sortedPosts.slice(0, MAX_RECENT);
---

<MainLayout title="Home">
  <section>
    <h1 class="mb-12 text-2xl font-bold text-zinc-900 dark:text-poi-focus">#human_centric_DX</h1>

    <div class="mb-6 font-sans leading-loose space-y-1">
  <p class="text-zinc-900 dark:text-poi-focus font-semibold">
    The hardest systems to build are the ones that disappear into the background.
  </p>
  <p class="text-zinc-900 dark:text-poi-focus font-semibold">
    Humans are the noisiest component. So I design around them.
  </p>
  <p class="text-light-accent dark:text-poi-accent font-semibold">
    That's what #human_centric_DX means.
  </p>
</div>
<div class="mb-8 border-l-2 border-zinc-200 dark:border-poi-border pl-4 font-sans text-sm text-zinc-500 dark:text-poi-muted leading-loose">
  技術が見えなくなるとき、はじめて人が主役になる。<br />
  人間がいちばん複雑だから、面白い。<br />
  その複雑さごと動くように設計します。
</div>
        
    <SocialList />
  </section>

  {pinnedPosts.length > 0 && (
    <section class="mt-16">
      <h2 class="mb-6 text-xl font-bold text-zinc-900 dark:text-poi-focus">Pinned Posts</h2>
      <ul class="space-y-4" role="list">
        {pinnedPosts.map((p) => (
          <li class="grid gap-1 sm:grid-cols-[auto_1fr] items-baseline">
            <PostPreview post={p} />
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="mt-16">
    <h2 class="mb-6 text-xl font-bold text-light-accent dark:text-poi-accent">
      <a href="/posts/">Posts</a>
    </h2>
    <ul class="space-y-4" role="list">
      {recentPosts.map((p) => (
        <li class="grid gap-1 sm:grid-cols-[auto_1fr] items-baseline">
          <PostPreview post={p} />
        </li>
      ))}
    </ul>
  </section>
</MainLayout>
