---
import MainLayout from '../layouts/MainLayout.astro';
import { works } from '../data/works';
import { getLucideIcon } from '../lib/lucide';
import { getBrandIcon } from '../lib/brand-icons';

const worksResolved = works.map(work => ({
  ...work,
  iconPath: getLucideIcon(work.icon),
  stackResolved: (work.stack ?? []).map(s => ({
    ...s,
    brandIcon: s.brand ? getBrandIcon(s.brand) : null,
  })),
}));

const categoryOrder = ["Automation", "Hardware", "Platform"];

const grouped = categoryOrder
  .map(cat => ({
    category: cat,
    items: worksResolved.filter(w => w.category === cat),
  }))
  .filter(g => g.items.length > 0);
---

<MainLayout title="Home">

  <!-- ===== Hero ===== -->
  <section class="mb-20">
    <div class="flex flex-col items-center gap-5 text-center">
      <img
        src="/images/profile/me.webp"
        alt="Katsuhiro Yamakawa"
        class="h-28 w-28 rounded-full object-cover"
      />
      <div class="max-w-sm">
        <h1 class="text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl dark:text-poi-focus">
          Katsuhiro Yamakawa
        </h1>
        <p class="mt-2 font-sans text-sm leading-7 text-zinc-600 dark:text-poi-muted">
          レガシーをバラして作り直すのが好き。<br />
          IoT・インフラ自動化・NixOS。<br />
          AIエージェントを実務に組み込む実験を続けている。
        </p>
      </div>
    </div>
  </section>

  <!-- ===== Works ===== -->
  <section class="mb-16">
    <div class="space-y-12">
      {grouped.map(({ category, items }) => (
        <div>
          <h2
            class="mb-6 font-mono text-5xl font-normal tracking-tight select-none opacity-60"
            style={`-webkit-text-stroke: 1px ${items[0].color}; color: transparent;`}
          >
            {category}
          </h2>

          <div class="space-y-6">
            {items.map((work) => (
              <div class="flex gap-4">
                <div class="mt-0.5 shrink-0 flex items-center justify-center w-9 h-9 rounded-lg bg-zinc-100 dark:bg-zinc-800">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16" height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-zinc-600 dark:text-zinc-400"
                    set:html={work.iconPath}
                  />
                </div>

                <div class="min-w-0 flex-1">
                  <h3 class="font-semibold text-base text-zinc-900 dark:text-poi-focus">
                    {work.title}
                  </h3>
                  <p class="mt-1 font-sans text-xs leading-6 text-zinc-500 dark:text-poi-muted whitespace-pre-line line-clamp-2">
                    {work.description}
                  </p>

                  {work.stackResolved.length > 0 && (
                    <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1">
                      {work.stackResolved.map((s) => (
                        <span class="inline-flex items-center gap-1 font-mono text-xs text-zinc-400 dark:text-zinc-500">
                          {s.brandIcon && (
                            <svg
                              width="12" height="12"
                              viewBox="0 0 24 24"
                              fill="currentColor"
                              style={`color:#${s.brandIcon.hex}`}
                              aria-hidden="true"
                            >
                              <path d={s.brandIcon.path} />
                            </svg>
                          )}
                          {s.label}
                        </span>
                      ))}
                    </div>
                  )}

                  <div class="mt-3 flex flex-wrap gap-2 font-mono text-xs">
                    {work.links.map((link) => (
                      <a
                        class="rounded-full border px-3 py-0.5 transition-opacity hover:opacity-70"
                        style={`color: ${work.color}; border-color: ${work.color}33;`}
                        href={link.href}
                        target={link.external ? "_blank" : undefined}
                        rel={link.external ? "noopener noreferrer" : undefined}
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

</MainLayout>
