---
import MainLayout from '../layouts/MainLayout.astro';
import { works } from '../data/works';
import { getLucideIcon } from '../lib/lucide';
import { getBrandIcon } from '../lib/brand-icons';

const worksResolved = works.map(work => ({
  ...work,
  iconPath: getLucideIcon(work.icon),
  stackResolved: (work.stack ?? []).map(s => ({
    ...s,
    brandIcon: s.brand ? getBrandIcon(s.brand) : null,
  })),
}));
---

<MainLayout title="Home">

  <!-- ===== Hero ===== -->
  <section class="mb-8">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center">
      <img
        src="/images/profile/me.webp"
        alt="Katsuhiro Yamakawa"
        class="h-20 w-20 shrink-0 rounded-full object-cover sm:h-24 sm:w-24"
      />
      <div class="min-w-0">
        <h1 class="text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl dark:text-poi-focus">
          Katsuhiro Yamakawa
        </h1>
      </div>
    </div>
  </section>

  <!-- ===== Description ===== -->
  <section class="mb-12 max-w-3xl">
    <p class="font-sans text-sm leading-7 text-zinc-600 dark:text-poi-muted">
      レガシーをバラして作り直すのが好き。IoT・インフラ自動化・NixOS。<br />
      AIエージェントを実務に組み込む実験を続けている。
    </p>
  </section>

  <!-- ===== Works ===== -->
  <section class="mb-12">
    <h2 class="mb-4 font-mono text-xs font-semibold text-zinc-900 dark:text-poi-focus">Works</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {worksResolved.map((work) => (
        <div
          class="rounded-xl border border-zinc-200 border-l-2 bg-white p-5 transition-colors hover:border-zinc-300 dark:border-poi-border dark:bg-poi-panel dark:hover:border-zinc-600"
          style={`border-left-color: ${work.color};`}
        >
          <div class="flex items-start gap-3 mb-3">
            <div
              class="shrink-0 flex items-center justify-center w-10 h-10 rounded-lg"
              style={`background:${work.color}18`}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="17" height="17"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                style={`color:${work.color}`}
                set:html={work.iconPath}
              />
            </div>
            <div class="min-w-0">
              <span
                class="inline-flex items-center rounded-full px-2 py-0.5 font-mono text-[10px]"
                style={`background: ${work.color}15; color: ${work.color};`}
              >
                {work.tag}
              </span>
              <h3 class="mt-1 font-semibold text-sm text-zinc-900 dark:text-poi-focus">{work.title}</h3>
            </div>
          </div>

          <p class="font-sans text-xs leading-6 text-zinc-500 dark:text-poi-muted">
            {work.description}
          </p>

          {work.stackResolved.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5">
              {work.stackResolved.map((s) => (
                <span class="inline-flex items-center gap-1 rounded-full border border-zinc-200 dark:border-poi-border px-2 py-0.5 font-mono text-[10px] text-zinc-500 dark:text-zinc-400">
                  {s.brandIcon && (
                    <svg
                      width="10" height="10"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      style={`color:#${s.brandIcon.hex}`}
                      aria-hidden="true"
                    >
                      <path d={s.brandIcon.path} />
                    </svg>
                  )}
                  {s.label}
                </span>
              ))}
            </div>
          )}

          <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 font-mono text-xs">
            {work.links.map((link) => (
              <a
                class="hover:underline underline-offset-2 transition-opacity hover:opacity-80"
                style={`color: ${work.color};`}
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noopener noreferrer" : undefined}
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

</MainLayout>
