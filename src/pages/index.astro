---
import MainLayout from '../layouts/MainLayout.astro';
import HeroMobile from '../components/HeroMobile.astro';
import HeroDesktop from '../components/HeroDesktop.astro';
import { works } from '../data/works';
import { getLucideIcon } from '../lib/lucide';
import { getBrandIcon } from '../lib/brand-icons';

const worksResolved = works.map(work => ({
  ...work,
  iconPath: getLucideIcon(work.icon),
  stackResolved: (work.stack ?? []).map(s => ({
    ...s,
    brandIcon: s.brand ? getBrandIcon(s.brand) : null,
  })),
}));

const categoryOrder = ["Hardware", "Modernization", "Finance"];

const grouped = categoryOrder
  .map(cat => ({
    category: cat,
    items: worksResolved.filter(w => w.category === cat),
  }))
  .filter(g => g.items.length > 0);
---

<MainLayout title="Home">

  <!-- ===== Mobile Hero (縦積み: Hero → Works) ===== -->
  <div class="sm:hidden mb-12">
    <HeroMobile />
  </div>

  <!-- ===== Desktop: 2カラム (Hero sticky left / Works flex-1 right) ===== -->
  <div class="flex gap-12">

    <!-- Hero: sticky サイドバー (desktop only) -->
    <HeroDesktop />

    <!-- Works: スクロール領域 -->
    <main class="flex-1 min-w-0">
      <div class="space-y-12">
        {grouped.map(({ category, items }) => (
          <div>
            <h2
              class="mb-6 font-mono text-5xl font-normal tracking-tight select-none opacity-60"
              style={`-webkit-text-stroke: 1px ${items[0].color}; color: transparent;`}
            >
              {category}
            </h2>

            <div class="space-y-6">
              {items.map((work) => (
                <div>
                  <h3 class="flex items-center gap-2 font-semibold text-lg text-zinc-900 dark:text-poi-focus">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16" height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="text-zinc-600 dark:text-zinc-400 shrink-0"
                      set:html={work.iconPath}
                    />
                    {work.title}
                  </h3>
                  <p class="mt-1 font-sans text-sm leading-6 text-zinc-500 dark:text-poi-muted whitespace-pre-line line-clamp-none sm:line-clamp-2">
                    {work.description}
                  </p>

                  {work.stackResolved.length > 0 && (
                    <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1">
                      {work.stackResolved.map((s) => (
                        <span class="inline-flex items-center gap-1 font-mono text-xs text-zinc-400 dark:text-zinc-500">
                          {s.brandIcon && (
                            <svg
                              width="12" height="12"
                              viewBox="0 0 24 24"
                              fill="currentColor"
                              style={`color:#${s.brandIcon.hex}`}
                              aria-hidden="true"
                            >
                              <path d={s.brandIcon.path} />
                            </svg>
                          )}
                          {s.label}
                        </span>
                      ))}
                    </div>
                  )}

                  <div class="mt-3 flex flex-wrap gap-2 font-mono text-sm">
                    {work.links.map((link) => (
                      <a
                        class="rounded-full border px-3 py-0.5 transition-opacity hover:opacity-70"
                        style={`color: ${work.color}; border-color: ${work.color}33;`}
                        href={link.href}
                        target={link.external ? "_blank" : undefined}
                        rel={link.external ? "noopener noreferrer" : undefined}
                      >
                        {link.label}
                      </a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </main>

  </div>

</MainLayout>
