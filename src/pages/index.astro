---
import MainLayout from '../layouts/MainLayout.astro';
import { works } from '../data/works';
import { getLucideIcon } from '../lib/lucide';
import { getBrandIcon } from '../lib/brand-icons';

type StackItem = { label: string; icon: string; type: "brand" | "lucide" };

const stackItems: StackItem[] = [
  { label: "Raspberry Pi", icon: "raspberry-pi", type: "brand" },
  { label: "Pico W",       icon: "cpu",          type: "lucide" },
  { label: "ESP32",        icon: "espressif",    type: "brand" },
  { label: "LoRa32",       icon: "cpu",          type: "lucide" },
  { label: "Cloudflare",   icon: "cloudflare",   type: "brand" },
  { label: "NixOS",        icon: "nixos",        type: "brand" },
  { label: "Python",       icon: "python",       type: "brand" },
];

const stackResolved = stackItems.map(item => ({
  ...item,
  brand: item.type === "brand" ? getBrandIcon(item.icon) : null,
  lucidePath: item.type === "lucide" ? getLucideIcon(item.icon) : null,
}));

const featuredWorks = works.filter(w => w.featured).map(work => ({
  ...work,
  iconPath: getLucideIcon(work.icon),
}));
---

<MainLayout title="Home">

  <!-- ===== Hero ===== -->
  <section class="mb-12">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start">
      <img
        src="/images/profile/me.webp"
        alt="Katsuhiro Yamakawa"
        class="h-20 w-20 shrink-0 rounded-full object-cover sm:h-24 sm:w-24"
      />
      <div class="min-w-0">
        <h1 class="text-2xl font-semibold tracking-tight text-zinc-900 sm:text-3xl dark:text-poi-focus">
          Katsuhiro Yamakawa
        </h1>
        <p class="mt-1 font-mono text-sm text-zinc-500 dark:text-poi-muted">Builder / Operator</p>

        <!-- Stack row with icons -->
        <div class="mt-4 flex flex-wrap items-center gap-x-1 gap-y-1">
          {stackResolved.map((item) => (
            <span class="inline-flex items-center gap-1.5 font-mono text-xs text-zinc-600 dark:text-zinc-400 bg-black/[.08] dark:bg-white/[.08] rounded px-1.5 py-1">
              {item.brand && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="13" height="13"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  style={`color:#${item.brand.hex}`}
                  aria-hidden="true"
                >
                  <path d={item.brand.path} />
                </svg>
              )}
              {item.lucidePath && (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="13" height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={item.lucidePath}
                />
              )}
              {item.label}
            </span>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ===== Tagline + Description ===== -->
  <section class="mb-10 max-w-3xl">
    <blockquote class="border-l-4 border-light-accent pl-5 dark:border-poi-accent">
      <p class="font-sans text-base italic leading-8 text-zinc-600 dark:text-poi-muted">
        Systems that disappear into the workflow.
      </p>
    </blockquote>
    <p class="mt-4 font-sans text-sm leading-7 text-zinc-600 dark:text-poi-muted">
      現場のカオスをちょうどいい粒感のシステムに。ハードウェアからクラウドまで、設計・実装・運用を一人で完結させています。
    </p>
  </section>

  <!-- ===== Works ===== -->
  <section class="mb-6">
    <div class="flex items-baseline justify-between mb-1">
      <div class="flex items-baseline gap-3">
        <h2 class="font-mono text-xs font-semibold text-zinc-900 dark:text-poi-focus">Works</h2>
        <span class="font-mono text-xs text-zinc-400 dark:text-zinc-500">{featuredWorks.length} in production</span>
      </div>
      <a class="cactus-link font-mono text-xs" href="/works/">すべて見る →</a>
    </div>
    <div class="divide-y divide-zinc-100 dark:divide-poi-border/60">
      {featuredWorks.map((work) => (
        <div class="py-4 flex gap-4 items-start">
          <div
            class="mt-0.5 shrink-0 flex items-center justify-center w-8 h-8 rounded-lg"
            style={`background:${work.color}18`}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15" height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              style={`color:${work.color}`}
              set:html={work.iconPath}
            />
          </div>
          <div class="min-w-0 flex-1">
            <p class="font-mono text-xs" style={`color:${work.color}`}>{work.tag}</p>
            <h3 class="mt-0.5 font-semibold text-sm text-zinc-900 dark:text-poi-focus">{work.title}</h3>
            <p class="mt-1 font-sans text-xs leading-6 text-zinc-500 dark:text-poi-muted">
              {work.featuredDescription ?? work.description}
            </p>
            <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 font-mono text-xs">
              {work.links.map((link) => (
                <a
                  class="hover:underline underline-offset-2 transition-opacity hover:opacity-80"
                  style={`color:${work.color}`}
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== Likes ===== -->
  <section class="mb-16 mt-2">
    <p class="font-mono text-xs flex flex-wrap items-center gap-x-2">
      <span class="font-mono text-xs font-semibold text-zinc-900 dark:text-poi-focus">Likes</span>
      <span class="text-zinc-300 dark:text-poi-border">·</span>
      <a href="/photos/" class="inline-flex items-center gap-1 text-light-accent dark:text-poi-accent hover:opacity-80 transition-opacity">
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={getLucideIcon('camera')} />
        Photography
      </a>
      <span class="text-zinc-300 dark:text-poi-border">·</span>
      <span class="inline-flex items-center gap-1 text-zinc-500 dark:text-poi-muted">
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={getLucideIcon('map-pin')} />
        Geoguessr
      </span>
      <span class="text-zinc-300 dark:text-poi-border">·</span>
      <span class="inline-flex items-center gap-1 text-zinc-500 dark:text-poi-muted">
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={getLucideIcon('bike')} />
        Bike
      </span>
    </p>
  </section>

  <!-- ===== Footer nav ===== -->
  <section class="border-t border-zinc-100 dark:border-poi-border pt-8 space-y-2">
    <p class="font-mono text-xs">
      <a href="/posts/" class="text-light-accent dark:text-poi-accent hover:underline">Posts</a>
      <span class="text-zinc-300 dark:text-poi-border mx-2">—</span>
      <span class="text-zinc-500 dark:text-poi-muted">設計の背景や判断の理由を書いています。</span>
    </p>
    <p class="font-mono text-xs">
      <a href="/contact/" class="text-light-accent dark:text-poi-accent hover:underline">Contact</a>
      <span class="text-zinc-300 dark:text-poi-border mx-2">—</span>
      <span class="text-zinc-500 dark:text-poi-muted">お問い合わせ・各種リンク。</span>
    </p>
  </section>

</MainLayout>
