---
import MainLayout from '../layouts/MainLayout.astro';
import HeroMobile from '../components/HeroMobile.astro';
import HeroDesktop from '../components/HeroDesktop.astro';
import { works } from '../data/works';
import About from '../components/About.astro';
import Approach from '../components/Approach.astro';
import Impact from '../components/Impact.astro';
import { getLucideIcon } from '../lib/lucide';
import { getBrandIcon } from '../lib/brand-icons';

const worksResolved = works.map(work => ({
  ...work,
  iconPath: getLucideIcon(work.icon),
  // カード全体の主導線＝デモ（links の先頭）。残りは副アクション（制作記事・GitHub）。
  primaryHref: work.links[0]?.href,
  primaryExternal: work.links[0]?.external ?? false,
  subLinks: work.links.slice(1),
  stackResolved: (work.stack ?? []).map(s => ({
    ...s,
    brandIcon: s.brand ? getBrandIcon(s.brand) : null,
  })),
}));

const filterOrder = ["Hardware", "Modernization", "Trading", "Others"];

const categoryMeta: Record<string, string> = {
  Hardware: "クラウドにも依存にも縛られないエッジ。枯れた標準と Nix の再現性で、旧ハードでも確実に動かす。",
  Modernization: "密結合したレガシーを止めずに分解し、.NET 8 と AI エージェントへ段階的に作り直す。",
  Trading: "Web フレームワークに頼れない領域で、自動売買を設計し本番で走らせ続ける。",
  Others: "その他単発プロジェクト。",
};

const groupOf = (cat: string) => worksResolved.filter(w => w.category === cat);

const groups = filterOrder
  .map(cat => ({ category: cat, color: groupOf(cat)[0]?.color ?? "#5de4c7", items: groupOf(cat) }))
  .filter(g => g.items.length > 0);

---

<MainLayout title="Home">

  <!-- ===== Mobile Hero (縦積み: Hero → Works) ===== -->
  <div class="sm:hidden mb-16">
    <HeroMobile />
  </div>

  <!-- ===== Desktop: 2カラム (Hero sticky left / Works flex-1 right) ===== -->
  <div class="flex gap-12">

    <!-- Hero: sticky サイドバー (desktop only) -->
    <HeroDesktop />

    <!-- 右カラム: スライド・ビューポート（≥sm で横スライド / <sm は縦積み） -->
    <main class="flex-1 min-w-0">
      <div class="sm:h-[calc(100vh-8rem)] sm:overflow-hidden">
        <div
          id="slides-track"
          class="flex flex-col sm:flex-row sm:h-full sm:transition-transform sm:duration-300 sm:ease-out motion-reduce:sm:transition-none"
        >
          <!-- About -->
          <div class="slide w-full sm:shrink-0 sm:h-full sm:overflow-y-auto sm:pr-2" data-slide="about">
            <div class="max-w-xl"><About /></div>
          </div>
          <!-- Approach -->
          <div class="slide w-full sm:shrink-0 sm:h-full sm:overflow-y-auto sm:pr-2" data-slide="approach">
            <div class="max-w-xl"><Approach /></div>
          </div>
          <!-- Impact -->
          <div class="slide w-full sm:shrink-0 sm:h-full sm:overflow-y-auto sm:pr-2" data-slide="impact">
            <div class="max-w-xl"><Impact /></div>
          </div>
          <!-- Works -->
          <div class="slide w-full sm:shrink-0 sm:h-full sm:overflow-y-auto sm:pr-2" data-slide="works">
            <div class="max-w-xl">
              <div id="works" class="mb-8">
                <p class="mb-2 font-mono text-xs tracking-widest uppercase text-poi-accent">Works</p>
                <h2 class="text-lg sm:text-xl font-semibold leading-snug tracking-tight text-zinc-900 dark:text-poi-focus">
                  IoTデバイス、レガシー刷新、自動売買。
                </h2>
                <p class="mt-2 text-sm leading-7 text-zinc-600 dark:text-poi-muted">
                  重なりのない三領域を、それぞれ違う制約の中で、設計から運用まで一人で通してきた。
                </p>
              </div>

              <!-- 領域フィルタ（トグル: もう一度押すと全件に戻る） -->
              <div
                id="work-filter"
                class="mb-8 flex flex-wrap gap-2 font-mono text-xs"
                role="group"
                aria-label="領域で絞り込む"
              >
                {groups.map(({ category, color, items }) => (
                  <button
                    type="button"
                    class="work-filter-btn inline-flex items-center gap-1.5 rounded-full border px-3 py-1 tracking-widest uppercase transition-colors"
                    data-category={category}
                    aria-pressed="false"
                    style={`--c:${color}; color:${color}; border-color:${color}33;`}
                  >
                    {category}
                    <span class="text-zinc-400 dark:text-zinc-500 normal-case tracking-normal">{items.length}</span>
                  </button>
                ))}
              </div>

              <div id="work-groups">
                {groups.map(({ category, color, items }, i) => (
                  <section class="work-group" data-category={category} class:list={[i > 0 && "mt-12"]}>
                    <div class="mb-5">
                      <p class="font-mono text-xs font-medium tracking-widest uppercase mb-1" style={`color:${color}`}>
                        {category}
                      </p>
                      <p class="text-sm text-zinc-500 dark:text-poi-muted">{categoryMeta[category]}</p>
                    </div>

                    <div class="space-y-4">
                      {items.map((work) => (
                        <article
                          class="work-card group/card relative rounded-xl border border-zinc-300/80 dark:border-poi-border/60 bg-white/40 dark:bg-white/[0.02] p-5 transition-all hover:-translate-y-0.5 hover:border-zinc-300 dark:hover:border-poi-border/80 hover:shadow-sm"
                        >
                          <h3 class="flex items-center gap-2 font-semibold text-lg text-zinc-900 dark:text-poi-focus">
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              width="16" height="16" viewBox="0 0 24 24"
                              fill="none" stroke="currentColor" stroke-width="1.5"
                              stroke-linecap="round" stroke-linejoin="round"
                              class="text-zinc-600 dark:text-zinc-400 shrink-0"
                              set:html={work.iconPath}
                            />
                            <!-- カード全体を覆う主導線（::after でカード面をクリック可能に） -->
                            <a
                              class="after:absolute after:inset-0 after:content-[''] after:rounded-xl transition-colors group-hover/card:text-[var(--c)] outline-none focus-visible:underline"
                              style={`--c:${work.color}`}
                              href={work.primaryHref}
                              target={work.primaryExternal ? "_blank" : undefined}
                              rel={work.primaryExternal ? "noopener noreferrer" : undefined}
                            >
                              {work.title}
                            </a>
                            {work.publishedAt && (
                              <span class="ml-auto font-mono text-[11px] font-normal text-zinc-400 dark:text-zinc-500">
                                {work.publishedAt}
                              </span>
                            )}
                          </h3>

                          {work.inUse && (
                            <p class="mt-1 flex items-center gap-1.5 text-xs">
                              <span class="inline-block h-1.5 w-1.5 rounded-full shrink-0 bg-emerald-500"></span>
                              <span class="text-emerald-600 dark:text-emerald-400">現場に導入・稼働中</span>
                            </p>
                          )}

                          <p class="mt-1.5 font-sans text-sm leading-6 text-zinc-500 dark:text-poi-muted whitespace-pre-line">
                            {work.description}
                          </p>

                          {work.rationale && (
                            <p
                              class="mt-3 border-l-2 pl-3 text-xs leading-6 text-zinc-500 dark:text-poi-muted"
                              style={`border-color:${work.color}55`}
                            >
                              {work.rationale}
                            </p>
                          )}

                          {work.stackResolved.length > 0 && (
                            <div class="mt-3 flex flex-wrap gap-x-3 gap-y-1">
                              {work.stackResolved.map((s) => (
                                <span class="inline-flex items-center gap-1 font-mono text-xs text-zinc-400 dark:text-zinc-500">
                                  {s.brandIcon && (
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" style={`color:#${s.brandIcon.hex}`} aria-hidden="true">
                                      <path d={s.brandIcon.path} />
                                    </svg>
                                  )}
                                  {s.label}
                                </span>
                              ))}
                            </div>
                          )}

                          {work.subLinks.length > 0 && (
                            <!-- 副アクション（relative z-10 で主導線の ::after より前面に出してクリックを奪う） -->
                            <div class="relative z-10 mt-4 flex flex-wrap gap-2 font-mono text-xs">
                              {work.subLinks.map((link) => (
                                <a
                                  class="inline-flex items-center rounded-md border px-2.5 py-1 text-zinc-500 dark:text-zinc-400 transition-colors hover:border-[var(--c)] hover:text-[var(--c)]"
                                  style={`--c:${work.color}; border-color:${work.color}55`}
                                  href={link.href}
                                  target={link.external ? "_blank" : undefined}
                                  rel={link.external ? "noopener noreferrer" : undefined}
                                >
                                  {link.label}
                                </a>
                              ))}
                            </div>
                          )}
                        </article>
                      ))}
                    </div>
                  </section>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 順送りコントロール（デスクトップのみ） -->
      <nav class="mt-6 hidden sm:flex items-center gap-5 max-w-xl font-mono text-xs text-zinc-500 dark:text-poi-muted" aria-label="セクション送り">
        <button id="slide-prev" type="button" aria-label="前のセクション"
          class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-zinc-300 dark:border-poi-border transition-colors hover:border-poi-accent hover:text-poi-accent disabled:opacity-30 disabled:hover:border-zinc-300 dark:disabled:hover:border-poi-border disabled:hover:text-inherit">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={getLucideIcon('arrow-right')} style="transform:scaleX(-1)" />
        </button>
        <span id="slide-progress" class="tabular-nums">1 / 4</span>
        <button id="slide-next" type="button" aria-label="次のセクション"
          class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-zinc-300 dark:border-poi-border transition-colors hover:border-poi-accent hover:text-poi-accent disabled:opacity-30 disabled:hover:border-zinc-300 dark:disabled:hover:border-poi-border disabled:hover:text-inherit">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={getLucideIcon('arrow-right')} />
        </button>
      </nav>
    </main>

  </div>

</MainLayout>

<script>
  // 領域フィルタ: タブを押すとその領域だけ表示。押されたタブを再度押すと全件に戻る。
  const filter = document.getElementById('work-filter');
  const groups = Array.from(document.querySelectorAll<HTMLElement>('.work-group'));
  const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.work-filter-btn'));
  let active: string | null = null;

  function apply() {
    for (const g of groups) {
      const show = active === null || g.dataset.category === active;
      g.style.display = show ? '' : 'none';
      if (show) {
        // リフロー時の軽いフェードで「触った手応え」を出す
        g.style.animation = 'none';
        // eslint-disable-next-line @typescript-eslint/no-unused-expressions
        g.offsetHeight; // reflow
        g.style.animation = 'work-fade .28s ease-out';
      }
    }
    for (const b of buttons) {
      const on = b.dataset.category === active;
      b.setAttribute('aria-pressed', String(on));
      b.style.backgroundColor = on ? `color-mix(in srgb, var(--c) 14%, transparent)` : '';
      b.style.borderColor = on ? `var(--c)` : `color-mix(in srgb, var(--c) 20%, transparent)`;
    }
  }

  filter?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.work-filter-btn');
    if (!btn) return;
    const cat = btn.dataset.category!;
    active = active === cat ? null : cat; // トグル
    apply();
  });
</script>

<script>
  const mq = window.matchMedia('(min-width: 640px)');
  const track = document.getElementById('slides-track');
  const slides = ['about', 'approach', 'impact', 'works'];
  const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]'));
  const prevBtn = document.getElementById('slide-prev');
  const nextBtn = document.getElementById('slide-next');
  const progress = document.getElementById('slide-progress');
  let index = 0;

  const clamp = (i: number) => Math.max(0, Math.min(slides.length - 1, i));

  function render() {
    if (track) {
      track.style.transform = mq.matches ? `translateX(-${index * 100}%)` : '';
    }
    for (const link of navLinks) {
      const on = mq.matches && link.dataset.section === slides[index];
      link.style.color = on ? '#5de4c7' : '';
    }
    if (progress) progress.textContent = `${index + 1} / ${slides.length}`;
    if (prevBtn) (prevBtn as HTMLButtonElement).disabled = index === 0;
    if (nextBtn) (nextBtn as HTMLButtonElement).disabled = index === slides.length - 1;
    history.replaceState(null, '', `#${slides[index]}`);
  }

  function go(i: number) {
    index = clamp(i);
    render();
  }

  for (const link of navLinks) {
    link.addEventListener('click', (e) => {
      if (!mq.matches) return; // モバイルはアンカーで通常スクロール
      const target = slides.indexOf(link.dataset.section!);
      if (target < 0) return;
      e.preventDefault();
      go(target);
    });
  }
  prevBtn?.addEventListener('click', () => go(index - 1));
  nextBtn?.addEventListener('click', () => go(index + 1));
  window.addEventListener('keydown', (e) => {
    if (!mq.matches) return;
    if (e.key === 'ArrowLeft') go(index - 1);
    if (e.key === 'ArrowRight') go(index + 1);
  });
  mq.addEventListener('change', render);

  const hash = location.hash.replace('#', '');
  if (slides.includes(hash)) index = slides.indexOf(hash);
  render();
</script>

<style>
  @keyframes work-fade {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
