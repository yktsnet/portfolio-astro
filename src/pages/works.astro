---
import ProfileLayout from '../layouts/ProfileLayout.astro';
import HostingArchitecture from '../components/HostingArchitecture.astro';
import WorkCard from '../components/WorkCard.astro';
import WorkFilter from '../components/WorkFilter.astro';
import { works, getCategoryIcon } from '../data/works';
import { getLucideIcon } from '../lib/lucide';
import { getBrandIcon } from '../lib/brand-icons';

const worksResolved = works.map(work => ({
  ...work,
  iconPath: getLucideIcon(work.icon),
  // カード全体の主導線＝デモ（links の先頭）。残りは副アクション（制作記事・GitHub）。
  primaryHref: work.links[0]?.href,
  primaryExternal: work.links[0]?.external ?? false,
  subLinks: work.links.slice(1),
  stackResolved: (work.stack ?? []).map(s => ({
    ...s,
    brandIcon: s.brand ? getBrandIcon(s.brand) : null,
  })),
}));

// 現場導入（inUse trueが上）を第一キー、優先度（priority 昇順）を第二キー、時系列（publishedAt 降順）を第三キーとしてソート
const sortedWorks = [...worksResolved].sort((a, b) => {
  if (!!a.inUse !== !!b.inUse) {
    return a.inUse ? -1 : 1;
  }
  if (a.priority !== b.priority) {
    return a.priority - b.priority;
  }
  const dateA = a.publishedAt || "0000.00";
  const dateB = b.publishedAt || "0000.00";
  return dateB.localeCompare(dateA);
});

// ユニークなカテゴリタグの抽出（小文字、アルファベット順にソート）
const allUniqueCategoryTags = Array.from(
  new Set(works.flatMap(w => w.categoryTags))
).sort();

const resolvedTags = allUniqueCategoryTags.map(tag => {
  const count = works.filter(w => w.categoryTags.includes(tag)).length;
  return {
    name: tag,
    count,
    iconPath: getLucideIcon(getCategoryIcon(tag)),
  };
});
---

<ProfileLayout current="works" title="Works">
  {/* 上部: 共同ホスト基盤「NixOS + Docker」の解説と構成図モニター */}
  <HostingArchitecture />

  {/* フィルターパネル（コレクション説明・絞り込みトグル・404メッセージ） */}
  <WorkFilter resolvedTags={resolvedTags} />

  {/* 作品一覧 */}
  <div id="work-list" class="space-y-6">
    {sortedWorks.map((work, idx) => (
      <WorkCard work={work} idx={idx} />
    ))}
  </div>
</ProfileLayout>

<style>
  .work-card.glow-active {
    animation: card-glow-light 1.5s ease-out;
  }
  
  :global(.dark) .work-card.glow-active {
    animation: card-glow-dark 1.5s ease-out;
  }

  @keyframes card-glow-light {
    0%, 100% {
      border-color: rgba(212, 212, 216, 0.8);
      box-shadow: none;
    }
    15% {
      border-color: #d0679d; /* light.accent */
      box-shadow: 0 0 16px rgba(208, 103, 157, 0.25);
    }
  }

  @keyframes card-glow-dark {
    0%, 100% {
      border-color: rgba(48, 52, 70, 0.6);
      box-shadow: none;
    }
    15% {
      border-color: #5de4c7; /* poi.accent */
      box-shadow: 0 0 16px rgba(93, 228, 199, 0.25);
    }
  }
</style>
