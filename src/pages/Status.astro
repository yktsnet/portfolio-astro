---
import MainLayout from "../layouts/MainLayout.astro";
import StatusPage from "../components/status/StatusPage.astro";
import type { StatusPayload } from "../lib/status";

let statusData: StatusPayload | null = null;
let fetchError: string | null = null;

try {
  const res = await fetch(`${Astro.url.origin}/api/status`);
  if (res.ok) {
    statusData = await res.json();
  } else {
    fetchError = `api ${res.status}`;
  }
} catch (e) {
  fetchError = String(e);
}
---

<MainLayout
  title="Live Demo (Trading System)"
  description="自動売買パイプラインのライブメトリクス。Cloudflare KV + Astro SSR によるリアルタイムダッシュボード。"
>
  <StatusPage data={statusData} error={fetchError} />
</MainLayout>
