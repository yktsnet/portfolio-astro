---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Contact" description="お問い合わせ・各種リンク">
    <h1 class="mb-8 text-2xl font-bold text-zinc-900 dark:text-poi-focus">Contact</h1>

    <p class="font-sans text-base leading-8 text-zinc-700 dark:text-poi-focus/90">
      お仕事のご相談・ご依頼はフォームからご連絡ください。
      初回はどんな課題を抱えているかを聞かせていただければ十分です。
    </p>

    <!-- Social links -->
    <div class="mt-8 flex items-center gap-5">
      <!-- GitHub -->
      <a
        href="https://github.com/yktsnet"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-poi-focus transition-colors"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </a>

      <!-- X / Twitter -->
      <a
        href="https://x.com/yktsnet"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="X (Twitter)"
        class="text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-poi-focus transition-colors"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.63L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
        </svg>
      </a>

      <!-- Instagram -->
      <a
        href="https://www.instagram.com/ykatsu24/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-poi-focus transition-colors"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="mt-16 border-t border-zinc-200 pt-10 dark:border-zinc-700/40">
    <h2 class="mb-8 text-lg font-bold tracking-tight text-zinc-900 dark:text-poi-focus">お問い合わせ</h2>

    <form id="contact-form" class="space-y-4 max-w-md">
      <div>
        <label for="cf-name" class="block text-sm font-semibold text-zinc-700 dark:text-poi-focus/90 mb-1">
          名前 <span class="text-red-400">*</span>
        </label>
        <input
          type="text"
          id="cf-name"
          name="name"
          required
          class="w-full rounded-md border border-zinc-300 dark:border-zinc-600 bg-zinc-50 dark:bg-zinc-800/50 px-3 py-2 text-sm text-zinc-900 dark:text-poi-focus placeholder-zinc-400 dark:placeholder-zinc-500 focus:border-light-accent dark:focus:border-poi-accent focus:outline-none transition-colors"
        />
      </div>

      <div>
        <label for="cf-email" class="block text-sm font-semibold text-zinc-700 dark:text-poi-focus/90 mb-1">
          メールアドレス <span class="text-red-400">*</span>
        </label>
        <input
          type="email"
          id="cf-email"
          name="email"
          required
          class="w-full rounded-md border border-zinc-300 dark:border-zinc-600 bg-zinc-50 dark:bg-zinc-800/50 px-3 py-2 text-sm text-zinc-900 dark:text-poi-focus placeholder-zinc-400 dark:placeholder-zinc-500 focus:border-light-accent dark:focus:border-poi-accent focus:outline-none transition-colors"
        />
      </div>

      <div>
        <label for="cf-phone" class="block text-sm font-semibold text-zinc-700 dark:text-poi-focus/90 mb-1">
          電話番号 <span class="text-red-400">*</span>
        </label>
        <input
          type="tel"
          id="cf-phone"
          name="phone"
          required
          class="w-full rounded-md border border-zinc-300 dark:border-zinc-600 bg-zinc-50 dark:bg-zinc-800/50 px-3 py-2 text-sm text-zinc-900 dark:text-poi-focus placeholder-zinc-400 dark:placeholder-zinc-500 focus:border-light-accent dark:focus:border-poi-accent focus:outline-none transition-colors"
        />
      </div>

      <div>
        <label for="cf-category" class="block text-sm font-semibold text-zinc-700 dark:text-poi-focus/90 mb-1">
          ご相談の種類 <span class="text-red-400">*</span>
        </label>
        <select
          id="cf-category"
          name="category"
          required
          class="w-full rounded-md border border-zinc-300 dark:border-zinc-600 bg-zinc-50 dark:bg-zinc-800/50 px-3 py-2 text-sm text-zinc-900 dark:text-poi-focus focus:border-light-accent dark:focus:border-poi-accent focus:outline-none transition-colors"
        >
          <option value="" disabled selected>選択してください</option>
          <option value="現場システム開発">現場システム開発</option>
          <option value="Web 制作">Web 制作</option>
          <option value="その他">その他</option>
        </select>
      </div>

      <div>
        <label for="cf-message" class="block text-sm font-semibold text-zinc-700 dark:text-poi-focus/90 mb-1">
          メッセージ
        </label>
        <textarea
          id="cf-message"
          name="message"
          rows="4"
          class="w-full rounded-md border border-zinc-300 dark:border-zinc-600 bg-zinc-50 dark:bg-zinc-800/50 px-3 py-2 text-sm text-zinc-900 dark:text-poi-focus placeholder-zinc-400 dark:placeholder-zinc-500 focus:border-light-accent dark:focus:border-poi-accent focus:outline-none transition-colors resize-y"
        ></textarea>
      </div>
      <!-- Cloudflare Turnstile -->
      <div
        class="cf-turnstile"
        data-sitekey="0x4AAAAAACtlG-abZy2cvpsN"
        data-theme="auto"
      ></div>

        <button
  type="submit"
  class="rounded-md bg-zinc-700 dark:bg-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-100 dark:text-poi-focus/90 hover:bg-zinc-600 dark:hover:bg-zinc-600 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
>
  送信
</button>

      <p id="cf-status" class="text-sm hidden"></p>
    </form>
  </section>
</MainLayout>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script is:inline>

<script is:inline>
  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('button[type="submit"]');
    const status = document.getElementById('cf-status');

    btn.disabled = true;
    btn.textContent = '送信中…';
    status.classList.add('hidden');

    const body = {
      name: form.name.value,
      email: form.email.value,
      phone: form.phone.value,
      category: form.category.value,
      message: form.message.value,
      cfToken: form.querySelector('[name="cf-turnstile-response"]')?.value || '',
    };

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json();

      status.classList.remove('hidden');
      if (data.ok) {
        status.textContent = 'ありがとうございます。メッセージを送信しました。';
        status.className = 'text-sm text-green-600 dark:text-green-400';
        form.reset();
      } else {
        status.textContent = '送信に失敗しました。再度お試しください。';
        status.className = 'text-sm text-red-500';
      }
    } catch {
      status.classList.remove('hidden');
      status.textContent = 'ネットワークエラーが発生しました。';
      status.className = 'text-sm text-red-500';
    } finally {
      btn.disabled = false;
      btn.textContent = '送信';
    }
  });
</script>
