---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Contact" description="お問い合わせ・各種リンク">
  <h1 class="mb-6 text-xl font-semibold text-zinc-900 dark:text-poi-focus">Contact</h1>

  <p class="font-sans text-sm leading-7 text-zinc-600 dark:text-poi-muted">
    お仕事のご相談・ご依頼はフォームからご連絡ください。
    初回はどんな課題を抱えているかを聞かせていただければ十分です。
  </p>

  <!-- Contact Form -->
  <section class="mt-10">
    <h2 class="mb-6 text-base font-semibold text-zinc-900 dark:text-poi-focus">お問い合わせ</h2>

    <form id="contact-form" class="space-y-4 max-w-md">
      <div>
        <label for="cf-name" class="block text-sm font-semibold text-zinc-700 dark:text-poi-focus/90 mb-1">
          名前 <span class="text-red-400">*</span>
        </label>
        <input
          type="text"
          id="cf-name"
          name="name"
          required
          class="w-full rounded-md border border-zinc-300 dark:border-zinc-600 bg-zinc-50 dark:bg-zinc-800/50 px-3 py-2 text-sm text-zinc-900 dark:text-poi-focus placeholder-zinc-400 dark:placeholder-zinc-500 focus:border-light-accent dark:focus:border-poi-accent focus:outline-none transition-colors"
        />
      </div>

      <div>
        <label for="cf-email" class="block text-sm font-semibold text-zinc-700 dark:text-poi-focus/90 mb-1">
          メールアドレス <span class="text-red-400">*</span>
        </label>
        <input
          type="email"
          id="cf-email"
          name="email"
          required
          class="w-full rounded-md border border-zinc-300 dark:border-zinc-600 bg-zinc-50 dark:bg-zinc-800/50 px-3 py-2 text-sm text-zinc-900 dark:text-poi-focus placeholder-zinc-400 dark:placeholder-zinc-500 focus:border-light-accent dark:focus:border-poi-accent focus:outline-none transition-colors"
        />
      </div>

      <div>
        <label for="cf-phone" class="block text-sm font-semibold text-zinc-700 dark:text-poi-focus/90 mb-1">
          電話番号 <span class="text-red-400">*</span>
        </label>
        <input
          type="tel"
          id="cf-phone"
          name="phone"
          required
          class="w-full rounded-md border border-zinc-300 dark:border-zinc-600 bg-zinc-50 dark:bg-zinc-800/50 px-3 py-2 text-sm text-zinc-900 dark:text-poi-focus placeholder-zinc-400 dark:placeholder-zinc-500 focus:border-light-accent dark:focus:border-poi-accent focus:outline-none transition-colors"
        />
      </div>

      <div>
        <label for="cf-category" class="block text-sm font-semibold text-zinc-700 dark:text-poi-focus/90 mb-1">
          ご相談の種類 <span class="text-red-400">*</span>
        </label>
        <select
          id="cf-category"
          name="category"
          required
          class="w-full rounded-md border border-zinc-300 dark:border-zinc-600 bg-zinc-50 dark:bg-zinc-800/50 px-3 py-2 text-sm text-zinc-900 dark:text-poi-focus focus:border-light-accent dark:focus:border-poi-accent focus:outline-none transition-colors"
        >
          <option value="" disabled selected>選択してください</option>
          <option value="現場システム開発">現場システム開発</option>
          <option value="Web 制作">Web 制作</option>
          <option value="その他">その他</option>
        </select>
      </div>

      <div>
        <label for="cf-message" class="block text-sm font-semibold text-zinc-700 dark:text-poi-focus/90 mb-1">
          メッセージ
        </label>
        <textarea
          id="cf-message"
          name="message"
          rows="4"
          class="w-full rounded-md border border-zinc-300 dark:border-zinc-600 bg-zinc-50 dark:bg-zinc-800/50 px-3 py-2 text-sm text-zinc-900 dark:text-poi-focus placeholder-zinc-400 dark:placeholder-zinc-500 focus:border-light-accent dark:focus:border-poi-accent focus:outline-none transition-colors resize-y"
        ></textarea>
      </div>

      <!-- Cloudflare Turnstile -->
      <div
        class="cf-turnstile"
        data-sitekey="0x4AAAAAACtlG-abZy2cvpsN"
        data-theme="auto"
      ></div>

      <button
        type="submit"
        class="rounded-md bg-zinc-700 dark:bg-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-100 dark:text-poi-focus/90 hover:bg-zinc-600 dark:hover:bg-zinc-600 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
      >
        送信
      </button>

      <p id="cf-status" class="text-sm hidden"></p>
    </form>
  </section>
</MainLayout>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script is:inline>
  document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('button[type="submit"]');
    const status = document.getElementById('cf-status');

    btn.disabled = true;
    btn.textContent = '送信中…';
    status.classList.add('hidden');

    const body = {
      name: form.name.value,
      email: form.email.value,
      phone: form.phone.value,
      category: form.category.value,
      message: form.message.value,
      cfToken: form.querySelector('[name="cf-turnstile-response"]')?.value || '',
    };

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json();

      status.classList.remove('hidden');
      if (data.ok) {
        status.textContent = 'ありがとうございます。メッセージを送信しました。';
        status.className = 'text-sm text-green-600 dark:text-green-400';
        form.reset();
      } else {
        status.textContent = '送信に失敗しました。再度お試しください。';
        status.className = 'text-sm text-red-500';
      }
    } catch {
      status.classList.remove('hidden');
      status.textContent = 'ネットワークエラーが発生しました。';
      status.className = 'text-sm text-red-500';
    } finally {
      btn.disabled = false;
      btn.textContent = '送信';
    }
  });
</script>
